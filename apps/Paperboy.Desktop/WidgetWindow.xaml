<Window x:Class="Paperboy.Desktop.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paperboy 9bit"
        Width="360"
        Height="96"
        MinWidth="360"
        MinHeight="96"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Border x:Name="WidgetShell"
            CornerRadius="22"
            Background="#111827"
            BorderBrush="#60A5FA"
            BorderThickness="1"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="TileButton"
                        AutomationProperties.AutomationId="TileButton"
                        Grid.Column="0"
                        Width="52"
                        Height="52"
                        Margin="0,0,12,0"
                        Padding="0"
                        Background="#2563EB"
                        Foreground="White"
                        Click="TileButton_Click">
                    <TextBlock Text="PB" FontWeight="Bold" />
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Paperboy 9bit"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="16" />
                    <TextBlock x:Name="WidgetStatusText"
                               Text="Click to open model chat"
                               Foreground="#CBD5E1"
                               FontSize="12" />
                </StackPanel>
                <Button Grid.Column="2"
                        Content="×"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Click="Close_Click" />
            </Grid>

            <Grid x:Name="ExpandedPanel"
                  AutomationProperties.AutomationId="ExpandedPanel"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="WidgetModelCombo"
                              AutomationProperties.AutomationId="WidgetModelCombo"
                              SelectedIndex="0"
                              Margin="0,0,8,8">
                        <ComboBoxItem Content="qwen3-0.6b" />
                        <ComboBoxItem Content="qwen2.5-0.5b" />
                        <ComboBoxItem Content="phi-3.5-mini" />
                    </ComboBox>
                    <Button Grid.Column="1"
                            Content="Orchestrators"
                            Click="ShowOrchestrators_Click" />
                </Grid>

                <TextBox x:Name="WidgetResponseText"
                         AutomationProperties.AutomationId="WidgetResponseText"
                         Grid.Row="1"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Hidden"
                         FontFamily="Consolas"
                         FontSize="12"
                         MinHeight="150"
                         Background="#0F172A"
                         Foreground="#E5E7EB"
                         BorderBrush="#334155" />

                <TextBox x:Name="WidgetPromptText"
                         AutomationProperties.AutomationId="WidgetPromptText"
                         Grid.Row="2"
                         Margin="0,10,0,8"
                         MinHeight="38"
                         TextWrapping="Wrap"
                         Text="Explain how Paperboy helps deliver local model bundles in one concise sentence." />

                <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <Button x:Name="WidgetSendButton"
                            AutomationProperties.AutomationId="WidgetSendButton"
                            Content="Send"
                            Background="#22C55E"
                            Foreground="White"
                            Click="Send_Click" />
                    <Button Content="Finish pipeline"
                            Background="#F59E0B"
                            Foreground="White"
                            Click="FinishPipeline_Click" />
                    <Button Content="Collapse"
                            Click="Collapse_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
