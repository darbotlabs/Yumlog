<Window x:Class="Paperboy.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paperboy"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Background="#EEF2FF"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="24"
                Padding="24"
                Background="#111827">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Paperboy"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Pack files into lightweight manifest-backed bundles, then toss them wherever they need to go."
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#CBD5E1" />
                </StackPanel>
                <Border Grid.Column="1"
                        CornerRadius="999"
                        Background="#2563EB"
                        Padding="18,10"
                        VerticalAlignment="Center">
                    <TextBlock Text=".paperboy.zip"
                               Foreground="White"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,20,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="18"
                    Padding="18"
                    Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Payload"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PaperboyInk}" />
                            <TextBlock Text="Drop files or folders here, or use the buttons. Paperboy keeps a manifest of every tossed item."
                                       Margin="0,4,0,14"
                                       Foreground="{StaticResource PaperboyMuted}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Add files" Click="AddFiles_Click" />
                            <Button Content="Add folder" Click="AddFolder_Click" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="14"
                            Background="#F8FAFC">
                        <ListBox x:Name="SourceList"
                                 ItemsSource="{Binding Sources}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Extended"
                                 DisplayMemberPath="Display" />
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="Remove selected" Click="RemoveSelected_Click" />
                        <Button Content="Clear" Click="ClearSources_Click" />
                        <TextBlock x:Name="PayloadSummaryText"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,8"
                                   Foreground="{StaticResource PaperboyMuted}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="20,0,0,0"
                    CornerRadius="18"
                    Padding="18"
                    Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Bundle"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PaperboyInk}" />
                        <TextBlock Text="Choose output, compression, and optional toss destination."
                                   Margin="0,4,0,16"
                                   Foreground="{StaticResource PaperboyMuted}" />

                        <TextBlock Text="Output bundle" FontWeight="SemiBold" />
                        <DockPanel Margin="0,6,0,14">
                            <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseOutput_Click" />
                            <TextBox x:Name="OutputPathText" />
                        </DockPanel>

                        <TextBlock Text="Compression" FontWeight="SemiBold" />
                        <ComboBox x:Name="CompressionCombo" Margin="0,6,0,14" SelectedIndex="0">
                            <ComboBoxItem Content="SmallestSize" />
                            <ComboBoxItem Content="Optimal" />
                            <ComboBoxItem Content="Fastest" />
                            <ComboBoxItem Content="NoCompression" />
                        </ComboBox>

                        <CheckBox x:Name="IncludeHiddenCheck"
                                  Content="Include hidden and system files"
                                  Margin="0,0,0,10" />
                        <CheckBox x:Name="OverwriteCheck"
                                  Content="Overwrite existing bundle/output"
                                  IsChecked="True"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="Toss destination (optional)" FontWeight="SemiBold" />
                        <DockPanel Margin="0,6,0,18">
                            <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseToss_Click" />
                            <TextBox x:Name="TossPathText" />
                        </DockPanel>

                        <WrapPanel>
                            <Button Content="Pack bundle" Click="PackBundle_Click" Background="#2563EB" Foreground="White" />
                            <Button Content="Inspect bundle" Click="InspectBundle_Click" />
                            <Button Content="Unpack bundle" Click="UnpackBundle_Click" />
                            <Button Content="Toss bundle" Click="TossBundle_Click" />
                        </WrapPanel>

                        <UniformGrid Columns="2" Margin="0,18,0,12">
                            <Border CornerRadius="14" Background="#EFF6FF" Padding="14" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="Files" Foreground="{StaticResource PaperboyMuted}" />
                                    <TextBlock x:Name="FilesStatText" Text="0" FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="14" Background="#F0FDF4" Padding="14" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Bundle size" Foreground="{StaticResource PaperboyMuted}" />
                                    <TextBlock x:Name="BundleSizeStatText" Text="-" FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="Log" FontWeight="SemiBold" Margin="0,6,0,6" />
                        <TextBox x:Name="LogText"
                                 MinHeight="160"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                CornerRadius="14"
                Padding="12"
                Background="#DBEAFE">
            <TextBlock x:Name="StatusText"
                       Text="Ready. Add files or folders to create a tossable Paperboy bundle."
                       Foreground="#1E3A8A" />
        </Border>
    </Grid>
</Window>
