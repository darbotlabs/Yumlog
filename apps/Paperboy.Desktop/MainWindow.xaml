<Window x:Class="Paperboy.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cards="clr-namespace:Paperboy.Desktop.Cards"
        Title="Paperboy"
        Width="1320"
        Height="820"
        MinWidth="1120"
        MinHeight="680"
        Background="#EEF2FF"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                cards:AgentCard.Id="paperboy.hero"
                cards:AgentCard.Role="showcase"
                CornerRadius="24"
                Padding="24"
                Background="#111827">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="56"
                            Height="56"
                            CornerRadius="18"
                            Background="#1D4ED8"
                            Margin="0,0,16,0">
                        <Image Source="Assets/WindowsAppSDK128.png"
                               Width="34"
                               Height="34"
                               Stretch="Uniform" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Paperboy"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Text="Pack files into lightweight manifest-backed bundles, then toss them wherever they need to go."
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#CBD5E1" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border CornerRadius="999"
                            Background="#2563EB"
                            Padding="18,10"
                            Margin="0,0,8,0">
                        <TextBlock Text=".paperboy.zip"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border CornerRadius="999"
                            Background="#7C3AED"
                            Padding="18,10">
                        <TextBlock Text="MCP + Agent Cards"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,20,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.9*" />
                <ColumnDefinition Width="0.72*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    cards:AgentCard.Id="paperboy.payload"
                    cards:AgentCard.Role="source-picker"
                    CornerRadius="18"
                    Padding="18"
                    Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Payload"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PaperboyInk}" />
                            <TextBlock Text="Drop files or folders here, or use the buttons. Paperboy keeps a manifest of every tossed item."
                                       Margin="0,4,0,14"
                                       Foreground="{StaticResource PaperboyMuted}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Add files"
                                    cards:AgentCard.Action="addFiles"
                                    Click="AddFiles_Click" />
                            <Button Content="Add folder"
                                    cards:AgentCard.Action="addFolder"
                                    Click="AddFolder_Click" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="14"
                            Background="#F8FAFC">
                        <ListBox x:Name="SourceList"
                                 ItemsSource="{Binding Sources}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Extended"
                                 DisplayMemberPath="Display" />
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="Remove selected"
                                cards:AgentCard.Action="removeSelected"
                                Click="RemoveSelected_Click" />
                        <Button Content="Clear"
                                cards:AgentCard.Action="clear"
                                Click="ClearSources_Click" />
                        <TextBlock x:Name="PayloadSummaryText"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,8"
                                   Foreground="{StaticResource PaperboyMuted}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="20,0,0,0"
                    cards:AgentCard.Id="paperboy.bundle"
                    cards:AgentCard.Role="bundle-builder"
                    CornerRadius="18"
                    Padding="18"
                    Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Bundle"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PaperboyInk}" />
                        <TextBlock Text="Choose output, compression, and optional toss destination."
                                   Margin="0,4,0,16"
                                   Foreground="{StaticResource PaperboyMuted}" />

                        <TextBlock Text="Output bundle" FontWeight="SemiBold" />
                        <DockPanel Margin="0,6,0,14">
                            <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseOutput_Click" />
                            <TextBox x:Name="OutputPathText" />
                        </DockPanel>

                        <TextBlock Text="Compression" FontWeight="SemiBold" />
                        <ComboBox x:Name="CompressionCombo" Margin="0,6,0,14" SelectedIndex="0">
                            <ComboBoxItem Content="SmallestSize" />
                            <ComboBoxItem Content="Optimal" />
                            <ComboBoxItem Content="Fastest" />
                            <ComboBoxItem Content="NoCompression" />
                        </ComboBox>

                        <CheckBox x:Name="IncludeHiddenCheck"
                                  Content="Include hidden and system files"
                                  Margin="0,0,0,10" />
                        <CheckBox x:Name="OverwriteCheck"
                                  Content="Overwrite existing bundle/output"
                                  IsChecked="True"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="Toss destination (optional)" FontWeight="SemiBold" />
                        <DockPanel Margin="0,6,0,18">
                            <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseToss_Click" />
                            <TextBox x:Name="TossPathText" />
                        </DockPanel>

                        <Border cards:AgentCard.Id="paperboy.foundryLocal"
                                cards:AgentCard.Role="offline-metadata-pipeline"
                                CornerRadius="14"
                                Background="#F8FAFC"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Foundry Local offline tagging" FontWeight="Bold" />
                                <TextBlock Text="Classify/tag images, videos, audio, and documents using a local Foundry model endpoint."
                                           Foreground="{StaticResource PaperboyMuted}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,10" />

                                <TextBlock Text="Endpoint" FontWeight="SemiBold" />
                                <TextBox x:Name="FoundryEndpointText"
                                         Text="http://127.0.0.1:52495/v1"
                                         Margin="0,4,0,8" />

                                <TextBlock Text="Model" FontWeight="SemiBold" />
                                <TextBox x:Name="FoundryModelText"
                                         Text="qwen3.5-0.8b"
                                         Margin="0,4,0,8" />

                                <CheckBox x:Name="FoundryIncludeImagesCheck"
                                          Content="Send image content to vision-capable models"
                                          IsChecked="True"
                                          Margin="0,0,0,6" />
                                <CheckBox x:Name="FoundrySampleVideoCheck"
                                          Content="Sample first video frame with FFmpeg when available"
                                          IsChecked="True"
                                          Margin="0,0,0,10" />

                                <Button Content="Analyze payload"
                                        cards:AgentCard.Action="analyze"
                                        Click="AnalyzeFoundry_Click"
                                        Background="#7C3AED"
                                        Foreground="White" />
                            </StackPanel>
                        </Border>

                        <WrapPanel>
                            <Button Content="Pack bundle"
                                    cards:AgentCard.Action="pack"
                                    Click="PackBundle_Click"
                                    Background="#2563EB"
                                    Foreground="White" />
                            <Button Content="Inspect bundle"
                                    cards:AgentCard.Action="inspect"
                                    Click="InspectBundle_Click" />
                            <Button Content="Unpack bundle"
                                    cards:AgentCard.Action="unpack"
                                    Click="UnpackBundle_Click" />
                            <Button Content="Toss bundle"
                                    cards:AgentCard.Action="toss"
                                    Click="TossBundle_Click" />
                        </WrapPanel>

                        <UniformGrid Columns="2" Margin="0,18,0,12">
                            <Border CornerRadius="14" Background="#EFF6FF" Padding="14" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="Files" Foreground="{StaticResource PaperboyMuted}" />
                                    <TextBlock x:Name="FilesStatText" Text="0" FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="14" Background="#F0FDF4" Padding="14" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Bundle size" Foreground="{StaticResource PaperboyMuted}" />
                                    <TextBlock x:Name="BundleSizeStatText" Text="-" FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border CornerRadius="14" Background="#FEF3C7" Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Foundry tags" Foreground="{StaticResource PaperboyMuted}" />
                                <TextBlock x:Name="FoundryStatText" Text="Not analyzed" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Log" FontWeight="SemiBold" Margin="0,6,0,6" />
                        <TextBox x:Name="LogText"
                                 MinHeight="160"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Margin="20,0,0,0"
                    cards:AgentCard.Id="paperboy.livetile"
                    cards:AgentCard.Role="a2a-card"
                    CornerRadius="18"
                    Padding="18"
                    Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Agent Cards"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PaperboyInk}" />
                        <TextBlock Text="Composable schema for A2A livetiles and MCP-aware agents."
                                   Margin="0,4,0,16"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource PaperboyMuted}" />

                        <Border Style="{StaticResource TileBorder}" Background="#EEF2FF" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="paperboy.payload" FontWeight="Bold" />
                                <TextBlock Text="source-picker · fileDrop → sourcePaths[]" Foreground="{StaticResource PaperboyMuted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource TileBorder}" Background="#EFF6FF" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="paperboy.bundle" FontWeight="Bold" />
                                <TextBlock Text="bundle-builder · pack/inspect/unpack/toss" Foreground="{StaticResource PaperboyMuted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource TileBorder}" Background="#F5F3FF" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="paperboy.mcp" FontWeight="Bold" />
                                <TextBlock Text="stdio MCP tools for agents and automation" Foreground="{StaticResource PaperboyMuted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource TileBorder}" Background="#FFF7ED" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="paperboy.foundryLocal" FontWeight="Bold" />
                                <TextBlock Text="offline model tagging for image/video/audio metadata" Foreground="{StaticResource PaperboyMuted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource TileBorder}" Background="#F0FDF4" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="paperboy.livetile" FontWeight="Bold" />
                                <TextBlock Text="A2A interactive tile state and action schema" Foreground="{StaticResource PaperboyMuted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Button Content="Copy card schema"
                                cards:AgentCard.Action="copySchema"
                                Click="CopyCardSchema_Click"
                                Background="#7C3AED"
                                Foreground="White" />
                        <Button Content="Export card catalog"
                                cards:AgentCard.Action="exportCards"
                                Click="ExportCards_Click" />
                        <Button Content="Show MCP command"
                                cards:AgentCard.Id="paperboy.mcp"
                                cards:AgentCard.Action="showCommand"
                                Click="ShowMcpCommand_Click" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                CornerRadius="14"
                Padding="12"
                Background="#DBEAFE">
            <TextBlock x:Name="StatusText"
                       Text="Ready. Add files or folders to create a tossable Paperboy bundle."
                       Foreground="#1E3A8A" />
        </Border>
    </Grid>
</Window>
